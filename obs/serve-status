#!/usr/bin/env bash
# shellcheck disable=SC2016

set -euo pipefail

TWITCH_BROADCASTER_ID=${TWITCH_BROADCASTER_ID-447179030} #rwxrob default

PORT="${PORT:-8787}"
LOGIN="${LOGIN:-rwxrob}"
EMOJI_CACHE="/tmp/github-emojis.json"

fetch_emoji_map() {
	if [[ ! -f "$EMOJI_CACHE" ]]; then
		curl -s https://api.github.com/emojis >"$EMOJI_CACHE"
	fi
}

emoji_to_unicode() {

	local shortcode="${1#:}"
	shortcode="${shortcode%:}"

	fetch_emoji_map

	url=$(jq -r --arg e "$shortcode" '.[$e] // empty' "$EMOJI_CACHE")

	if [[ -z "$url" ]]; then
		printf '%s' "$1"
		return
	fi

	hex=$(printf '%s\n' "$url" | sed -E 's#.*/unicode/([0-9a-f-]+)\.png.*#\1#')

	printf '%b' "$(printf '\\U%s' "$hex")"
}

get_status() {

	# shellcheck disable=SC2016
	raw=$(gh api graphql -f query='
    query($login: String!) {
      user(login: $login) {
        status {
          emoji
          message
        }
      }
    }
  ' -F login="$LOGIN" --jq '.data.user.status | "\(.emoji) \(.message)"' 2>/dev/null || true)

	emoji="${raw%% *}"
	message="${raw#* }"

	unicode=$(emoji_to_unicode "$emoji")

	printf '%s %s\n' "$unicode" "$message" | sed 's/^ *//;s/ *$//'
}

have() {
	command -v "$1" >/dev/null 2>&1
}

update_twitch_title() {
	: "${TWITCH_BROADCASTER_ID:?missing TWITCH_BROADCASTER_ID}"

	local title out rc safe_title

	title="$1"
	title="${title:0:140}"
	safe_title="$(printf '%s' "$title" | sed 's/\\/\\\\/g; s/"/\\"/g')"

	set +e
	out="$(
		twitch api patch channels \
			-q "broadcaster_id=$TWITCH_BROADCASTER_ID" \
			-b "{\"title\":\"$safe_title\"}" \
			2>&1
	)"
	rc=$?
	set -e

	[[ $rc -ne 204 ]] || die "twitch title update failed: $out"
}

die() {
	printf '%s\n' "$*" >&2
	exit 1
}

serve_once() {

	body="$(get_status)"

	len=$(printf '%s' "$body" | wc -c | tr -d ' ')

	{
		printf 'HTTP/1.1 200 OK\r\n'
		printf 'Content-Type: text/plain; charset=utf-8\r\n'
		printf 'Access-Control-Allow-Origin: *\r\n'
		printf 'Content-Length: %s\r\n' "$len"
		printf '\r\n'
		printf '%s' "$body"
	}
}

echo "Serving GitHub status for $LOGIN on http://127.0.0.1:$PORT"

while true; do
	resp=$(serve_once)
	current=$(echo "$resp" | tail -1)
	prev=""
	if [[ -e "$HOME/.title" ]]; then
		prev=$(<"$HOME/.title")
	fi
	if [[ "$current" != "$prev" ]]; then
		echo "$current" >"$HOME/.title"
		update_twitch_title "$current"
	fi
	serve_once | nc -l "$PORT" >/dev/null 2>&1 || true
done
