#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'EOF'
usage:

  ghstatus clear
  ghstatus MESSAGE...
  ghstatus :emoji: MESSAGE...
  ghstatus -e :emoji: MESSAGE...
  ghstatus -x ISO8601 MESSAGE...
  ghstatus -e :emoji: -x ISO8601 MESSAGE...

examples:

  ghstatus hacking on bonzai
  ghstatus :computer: hacking on bonzai
  ghstatus -e :bicycle: out riding
  ghstatus -x 2026-03-08T18:00:00Z heads down writing
  ghstatus -e :house: -x 2026-03-08T23:00:00Z working from home

notes:

  clear removes your current GitHub status
  emoji must be a GitHub shortcode such as :computer: or :house:
  expiration must be ISO 8601, for example: 2026-03-08T18:00:00Z
EOF
	exit "${1:-0}"
}

if [[ ${1-} =~ ^[0-9]+$ ]]; then
	issue="$1"
	shift
	title="$(gh issue view "$issue" --json title -q .title)"
	echo exec "$0" ":gear: $title" "$@"
fi

require() {
	command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

clear_status() {

	# shellcheck disable=SC2016
	gh api graphql -f query='
mutation {
  changeUserStatus(input:{message:"", emoji:"", expiresAt:null, limitedAvailability:false}) {
    status {
      message
      emoji
      expiresAt
    }
  }
}' >/dev/null

}

emoji=':speech_balloon:'
expires_at=''
message=''

while [[ $# -gt 0 ]]; do
	case "$1" in
	clear)
		[[ $# -eq 1 ]] || die "clear does not take additional arguments"
		require gh
		clear_status
		exit 0
		;;
	-e | --emoji)
		shift
		[[ $# -gt 0 ]] || die "missing value for -e|--emoji"
		emoji="$1"
		;;
	-x | --expires | -t | --until)
		shift
		[[ $# -gt 0 ]] || die "missing value for -x|--expires"
		expires_at="$1"
		;;
	-h | --help)
		usage 0
		;;
	:*:)
		if [[ -z "$message" ]]; then
			emoji="$1"
		else
			message="${message:+$message }$1"
		fi
		;;
	*)
		message="${message:+$message }$1"
		;;
	esac
	shift
done

[[ -n "$message" ]] || usage 1

require gh

if [[ -n "$expires_at" ]]; then

	# shellcheck disable=SC2016
	gh api graphql \
		-f query='
mutation($message:String!,$emoji:String!,$expiresAt:DateTime) {
  changeUserStatus(input:{
    message:$message,
    emoji:$emoji,
    expiresAt:$expiresAt,
    limitedAvailability:false
  }) {
    status {
      message
      emoji
      expiresAt
    }
  }
}' \
		-F message="$message" \
		-F emoji="$emoji" \
		-F expiresAt="$expires_at" \
		--jq '.data.changeUserStatus.status | "\(.emoji // "") \(.message // "")"' |
		sed 's/^ *//;s/ *$//'
else

	# shellcheck disable=SC2016
	gh api graphql \
		-f query='
mutation($message:String!,$emoji:String!) {
  changeUserStatus(input:{
    message:$message,
    emoji:$emoji,
    limitedAvailability:false
  }) {
    status {
      message
      emoji
      expiresAt
    }
  }
}' \
		-F message="$message" \
		-F emoji="$emoji" \
		--jq '.data.changeUserStatus.status | "\(.emoji // "") \(.message // "")"' |
		sed 's/^ *//;s/ *$//'
fi
